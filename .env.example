// Everdream Bot — Environment Configuration
// Copy .env.example to .env and fill in your values

DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_server_id_here

// Channel IDs (right-click channel → Copy ID, with Developer Mode on)
WELCOME_CHANNEL_ID=
RULES_CHANNEL_ID=
GENERAL_CHANNEL_ID=
DREAM_JOURNAL_CHANNEL_ID=
ANNOUNCEMENTS_CHANNEL_ID=
BOT_LOG_CHANNEL_ID=

// Role IDs
MEMBER_ROLE_ID=
UNVERIFIED_ROLE_ID=

// Onboarding
// Number of seconds a user has to complete verification before being kicked (0 = disabled)
VERIFICATION_TIMEOUT_SECONDS=600
