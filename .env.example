// Everdream Bot — Environment Configuration
// Copy .env.example to .env and fill in your values

DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_server_id_here

// Channel IDs (populated by !setup-server, or set manually)
WELCOME_CHANNEL_ID=
RULES_CHANNEL_ID=
GENERAL_CHANNEL_ID=
DREAM_JOURNAL_CHANNEL_ID=
ANNOUNCEMENTS_CHANNEL_ID=
BOT_LOG_CHANNEL_ID=
TRADING_CHANNEL_ID=
LEADERBOARD_CHANNEL_ID=
INTRODUCTIONS_CHANNEL_ID=

// Role IDs (populated by !setup-server, or set manually)
MEMBER_ROLE_ID=
UNVERIFIED_ROLE_ID=
OWNER_ROLE_ID=
ADMIN_ROLE_ID=
MODERATOR_ROLE_ID=
MUTED_ROLE_ID=
CREATOR_ROLE_ID=
COLLECTOR_ROLE_ID=

// Web3
// JSON RPC endpoint for checking NFT ownership (e.g. Alchemy/Infura)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
// The NFT contract address for token-gating
NFT_CONTRACT_ADDRESS=0x
// Chain ID (1 = Ethereum mainnet, 137 = Polygon, 8453 = Base)
CHAIN_ID=1

// Base chain RPC (for contract interactions)
BASE_RPC_URL=https://mainnet.base.org

// Deployed contract addresses (Base chain)
XAELS_CONTRACT_ADDRESS=
TAOS_CONTRACT_ADDRESS=

// Bot wallet private key (for minting NFTs and TAOs on behalf of users)
// This wallet must have MINTER_ROLE on both contracts
BOT_PRIVATE_KEY=

// Pinata IPFS credentials
// Get these at https://app.pinata.cloud
PINATA_JWT=

// Onboarding
VERIFICATION_TIMEOUT_SECONDS=0

// Database path (relative to project root)
DB_PATH=./data/everdream.db
